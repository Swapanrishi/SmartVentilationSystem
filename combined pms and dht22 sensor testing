// --- BLYNK CREDENTIALS (MUST BE AT THE VERY TOP) ---
#define BLYNK_PRINT Serial
#define BLYNK_TEMPLATE_ID ""
#define BLYNK_TEMPLATE_NAME ""
#define BLYNK_AUTH_TOKEN ""


// --- LIBRARIES ---
#include <WiFi.h>
#include <WiFiClient.h>
#include <BlynkSimpleEsp32.h>
#include "DHT.h"

// --- WI-FI CREDENTIALS ---
// --- WI-FI CREDENTIALS ---
char ssid[] = "";
char pass[] = "";
// --- SENSOR SETUP ---
#define DHTPIN 4        
#define DHTTYPE DHT22   
DHT dht(DHTPIN, DHTTYPE);

void setup() {
  // Start PC Communication
  Serial.begin(115200);
  
  // Start PMS5003 Communication (Pins 16 and 17)
  Serial2.begin(9600, SERIAL_8N1, 16, 17);
  
  // Start DHT Sensor
  dht.begin();
  
  delay(1000);
  Serial.println("\n=================================");
  Serial.println(" BLYNK IOT NODE BOOTING...       ");
  Serial.println("=================================");

  // --- MANUAL WI-FI CONNECTION ---
  Serial.print("Attempting to connect to Wi-Fi: ");
  Serial.println(ssid);
  
  WiFi.begin(ssid,pass);
  
  // Wait here and print dots until connected
  int attempts = 0;
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
    attempts++;
    if (attempts > 20) {
      Serial.println("\n[ERROR] Could not connect to Hotspot! Check 2.4GHz setting.");
      attempts = 0; // Reset and keep trying
    }
  }

  Serial.println("\n[SUCCESS] Wi-Fi Connected!");
  Serial.print("ESP32 IP Address: ");
  Serial.println(WiFi.localIP());

  // --- START BLYNK ---
  Serial.println("Connecting to Blynk Cloud...");
  Blynk.config(BLYNK_AUTH_TOKEN);
  Blynk.connect();
}
void loop() {
  // This keeps the connection to the Blynk Cloud alive!
  Blynk.run(); 

  // 1. Wait for the PMS5003 to send data
  if (Serial2.available() > 0) {
    if (Serial2.read() == 0x42) {       
      delay(100);                       
      if (Serial2.available() >= 31) {
        if (Serial2.read() == 0x4D) {   
          
          // 2. Read the Dust Data
          uint8_t buffer[30];
          Serial2.readBytes(buffer, 30);

          int pm1 = (buffer[8] << 8) | buffer[9];
          int pm25 = (buffer[10] << 8) | buffer[11];
          int pm10 = (buffer[12] << 8) | buffer[13];

          // 3. Read the Climate Data
          float h = dht.readHumidity();
          float t = dht.readTemperature();

          // 4. Print the Unified Report to Serial Monitor
          Serial.println("\n+-------------------------------+");
          Serial.println("|   LIVE ENVIRONMENTAL REPORT   |");
          Serial.println("+-------------------------------+");
          
          if (isnan(h) || isnan(t)) {
            Serial.println("  [DHT ERROR] Check Wiring!");
          } else {
            Serial.print("  Temp     : "); Serial.print(t); Serial.println(" °C");
            Serial.print("  Humidity : "); Serial.print(h); Serial.println(" %");
            
            // --- PUSH CLIMATE TO BLYNK ---
            Blynk.virtualWrite(V0, t);
            Blynk.virtualWrite(V1, h);
          }
          
          Serial.println("  - - - - - - - - - - - - - - - -");
          Serial.print("  PM 1.0   : "); Serial.print(pm1); Serial.println(" ug/m3");
          Serial.print("  PM 2.5   : "); Serial.print(pm25); Serial.println(" ug/m3");
          Serial.print("  PM 10.0  : "); Serial.print(pm10); Serial.println(" ug/m3");
          Serial.println("+-------------------------------+");

          // --- PUSH DUST DATA TO BLYNK ---
          Blynk.virtualWrite(V2, pm1);
          Blynk.virtualWrite(V3, pm25);
          Blynk.virtualWrite(V4, pm10);

          // Clear any leftover bytes in the buffer and wait 2 seconds
          while(Serial2.available()) { Serial2.read(); }
          delay(2000); 
        }
      }
    }
  }
}
